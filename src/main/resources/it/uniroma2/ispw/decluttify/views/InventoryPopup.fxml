<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" prefHeight="500" prefWidth="400" spacing="15" style="-fx-padding: 20;" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.12" fx:controller="it.uniroma2.ispw.decluttify.view.controller.JavaFX.InventoryPopupController">
    <Label style="-fx-font-size: 18; -fx-font-weight: bold;" text="Your Inventory" />

    <ListView fx:id="inventoryListView" VBox.vgrow="ALWAYS" />

    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Button onAction="#handleClose" text="Cancel" />
        <Button onAction="#handleSelectItem" style="-fx-background-color: #3498db; -fx-text-fill: white;" text="Add to Proposal" />
    </HBox>
</VBox>
