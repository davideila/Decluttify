<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.uniroma2.ispw.decluttify.view.controller.JavaFX.ItemBrowserController">

    <center>
        <VBox alignment="TOP_CENTER" spacing="10.0">
            <Label style="-fx-font-size: 24px;" text="Explore Items">
            <VBox.margin>
               <Insets top="10.0" />
            </VBox.margin></Label>
         <HBox prefHeight="64.0" prefWidth="730.0" />
         <ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER" prefHeight="200.0" prefWidth="200.0" vbarPolicy="ALWAYS" VBox.vgrow="ALWAYS">
            <content>
               <TilePane fx:id="tilePane" hgap="15.0" vgap="15.0">
                  <padding>
                     <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                  </padding></TilePane>
            </content>
            <VBox.margin>
               <Insets />
            </VBox.margin>
         </ScrollPane>
         <BorderPane.margin>
            <Insets bottom="10.0" left="20.0" />
         </BorderPane.margin>
        </VBox>
    </center>
</BorderPane>
