<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Tab?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.ListView?>
<TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.uniroma2.ispw.decluttify.view.controller.JavaFX.MyOffersController">
    <tabs>
        <Tab text="Received Offers">
            <content>
                <VBox spacing="10.0">
                    <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                    </padding>
                    <children>
                        <HBox alignment="CENTER_LEFT" style="-fx-border-color: transparent transparent #cccccc transparent; -fx-border-width: 0 0 1 0;">
                            <children>
                                <Region HBox.hgrow="ALWAYS" />
                                <Label style="-fx-font-weight: bold; -fx-text-fill: #2ecc71;" text="YOU GET" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Region prefWidth="120" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label style="-fx-font-weight: bold; -fx-text-fill: #E57373;" text="YOU GIVE" />
                                <Region HBox.hgrow="ALWAYS" />
                            </children>
                            <padding>
                                <Insets bottom="5.0" left="15.0" right="15.0" top="5.0" />
                            </padding>
                        </HBox>
                        <ListView fx:id="listViewReceived" VBox.vgrow="ALWAYS" />
                    </children>
                </VBox>
            </content>
        </Tab>

        <Tab text="Sent Offers">
            <content>
                <VBox spacing="10.0">
                    <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                    </padding>
                    <children>
                        <HBox alignment="CENTER_LEFT" style="-fx-border-color: transparent transparent #cccccc transparent; -fx-border-width: 0 0 1 0;">
                            <children>
                                <Label style="-fx-font-weight: bold; -fx-text-fill: #2ecc71;" text="YOU GET" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label style="-fx-font-weight: bold; -fx-text-fill: #e67e22;" text="YOU GIVE" />
                            </children>
                            <padding>
                                <Insets bottom="5.0" left="15.0" right="15.0" top="5.0" />
                            </padding>
                        </HBox>
                        <ListView fx:id="listViewSent" VBox.vgrow="ALWAYS" />
                    </children>
                </VBox>
            </content>
        </Tab>
    </tabs>
</TabPane>