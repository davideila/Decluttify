<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<Button mnemonicParsing="false"  xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.uniroma2.ispw.decluttify.view.controller.JavaFX.ItemBrowserController">
   <graphic>
      <VBox prefHeight="200.0" prefWidth="100.0">
         <children>
            <StackPane prefHeight="150.0" prefWidth="200.0">
               <children>
                  <ImageView fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true" />
                  <ImageView fitHeight="30.0" fitWidth="30.0" pickOnBounds="true" preserveRatio="true" StackPane.alignment="TOP_RIGHT">
                      <Image url="@../images/music_icon.png" />
                  </ImageView>

               </children>
            </StackPane>
            <Label alignment="CENTER" text="Item title name" />
            <Label text="Description" />
            <Label text="Condition" />
            <Button mnemonicParsing="false" text="User" underline="true" wrapText="true" />
         </children>
      </VBox>
   </graphic>
</Button>
